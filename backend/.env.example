# MongoDB Connection String
# - Replace <username>, <password>, and <cluster-host> with your MongoDB Atlas values.
# - If your password contains special characters, URL-encode it.
# - Keep this file as an example only; put real secrets in backend/.env (not committed).
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/expense_tracker?retryWrites=true&w=majority

# JWT Secret Key (use a strong random string)
JWT_SECRET=your_secret_key_here

# Server Port
PORT=5000
